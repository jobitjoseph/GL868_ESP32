{
    "name": "GL868_ESP32",
    "version": "1.0.3",
    "description": "GPS tracking library for ESP32 with SIM868 modem. Features non-blocking operation, deep sleep power management, SMS/Call control, motion detection via LIS3DHTR, and offline data queuing.",
    "keywords": [
        "gps",
        "tracker",
        "sim868",
        "esp32",
        "gsm",
        "gprs",
        "sms",
        "call",
        "lis3dh",
        "accelerometer",
        "deep-sleep",
        "ws2812b",
        "led",
        "iot"
    ],
    "authors": [
        {
            "name": "Jobit Joseph",
            "email": "jobitjoseph1@gmail.com",
            "maintainer": true
        },
        {
            "name": "Circuit Digest"
        }
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Circuit-Digest/GL868_ESP32.git"
    },
    "license": "MIT",
    "frameworks": "arduino",
    "platforms": "espressif32",
    "dependencies": {
        "bblanchon/ArduinoJson": "^7.0.0"
    },
    "export": {
        "include": [
            "src/*",
            "examples/*",
            "library.properties",
            "keywords.txt",
